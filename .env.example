# Eliana — Frontend Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Supabase (required)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Live relay URL (required for Phase 2 live voice)
# Point to your Cloud Run relay deployment or local relay server
# VITE_LIVE_RELAY_URL=wss://eliana-relay-xxxx-uc.a.run.app

# NOTE: Never add provider API keys here.
# All live provider secrets belong in the relay server environment (relay/.env).
