# Eliana Relay — Environment Variables
# Copy to .env for local development. Never commit .env.

PORT=8080
NODE_ENV=development

# CORS: set to your frontend origin in production
ALLOWED_ORIGIN=http://localhost:5173

# Supabase (required for token validation)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Live provider API key (server-side ONLY — never expose to frontend)
LIVE_PROVIDER_API_KEY=your-gemini-api-key-here

# Provider WebSocket endpoint (defaults to Gemini Live if not set)
# LIVE_PROVIDER_WS_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContent
